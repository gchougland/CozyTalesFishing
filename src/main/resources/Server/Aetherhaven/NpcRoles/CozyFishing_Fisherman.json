{
  "Type": "Generic",
  "Parameters": {
    "Invulnerable": { "Value": false, "Description": "Whether the NPC is invulnerable." },
    "MemoriesNameOverride": { "Value": "CozyFishing_Fisherman", "Description": "Memory name override" },
    "NameTranslationKey": {
      "Value": "cozyfishing_npc.npcRoles.CozyFishing_Fisherman.name",
      "Description": "Translation key for NPC name display"
    },
    "AetherhavenWanderPhaseTime": { "Value": [4, 10], "Description": "Rect-wander phase duration bounds (seconds)" },
    "AetherhavenPausePhaseTime": { "Value": [3, 7], "Description": "Idle pause between wander bursts (seconds)" }
  },
  "StartState": "Idle",
  "AttitudeGroup": "Aetherhaven_Townsfolk",
  "DefaultNPCAttitude": "Neutral",
  "DefaultPlayerAttitude": "Neutral",
  "Appearance": "Fisherman",
  "MaxHealth": 200,
  "IsMemory": true,
  "MemoriesCategory": "Aetherhaven",
  "MemoriesNameOverride": { "Compute": "MemoriesNameOverride" },
  "DisableDamageGroups": ["Self", "Player", "Aetherhaven_Townsfolk", "Friendly"],
  "CombatConfig": { "EntityEffect": "Immunity_Environmental" },
  "BusyStates": ["$Interaction"],
  "Invulnerable": { "Compute": "Invulnerable" },
  "KnockbackScale": 0.5,
  "ApplySeparation": true,
  "SeparationDistance": 2.5,
  "SeparationMode": "Push",
  "SeparationPushDistanceWeightTarget": 8,
  "SeparationPushDistanceWeightAttacker": 8,
  "SeparationPushSafeDistanceMultiplier": 0.8,
  "SeparationPushSteeringStrength": 0.8,
  "SeparationPushSpeedScale": 0.5,
  "MotionControllerList": [
    {
      "Type": "Walk",
      "MaxWalkSpeed": 4,
      "Gravity": 10,
      "RunThreshold": 0.3,
      "MaxFallSpeed": 15,
      "MaxRotationSpeed": 360,
      "Acceleration": 10
    }
  ],
  "StateTransitions": [
    {
      "$Comment": "Clear Status-slot POI animation when Java returns NPC to Idle.",
      "States": [{ "From": ["AetherhavenAutonomy"], "To": ["Idle"] }],
      "Actions": { "Reference": "Component_ActionList_Aetherhaven_Clear_Status" }
    }
  ],
  "Instructions": [
    {
      "Continue": true,
      "Instructions": [
        {
          "Sensor": {
            "Type": "Not",
            "Sensor": { "Type": "State", "State": "Flee" }
          },
          "Instructions": [
            {
              "Sensor": { "Type": "Damage", "Combat": true },
              "Actions": [{ "Type": "State", "State": "Flee" }]
            },
            {
              "Sensor": {
                "Type": "Mob",
                "Range": 10,
                "Filters": [{ "Type": "NPCGroup", "IncludeGroups": ["Aggressive"] }]
              },
              "BodyMotion": {
                "Type": "Flee",
                "SlowDownDistance": 12,
                "StopDistance": 18,
                "RelativeSpeed": 0.85
              }
            }
          ]
        },
        {
          "Sensor": { "Type": "State", "State": "Flee" },
          "Instructions": [
            {
              "Sensor": {
                "Type": "Mob",
                "Range": 12,
                "Filters": [{ "Type": "NPCGroup", "IncludeGroups": ["Aggressive"] }]
              },
              "BodyMotion": {
                "Type": "Flee",
                "SlowDownDistance": 12,
                "StopDistance": 18,
                "RelativeSpeed": 0.9
              }
            },
            {
              "Sensor": { "Type": "Any" },
              "Actions": [{ "Type": "State", "State": "Idle" }]
            }
          ]
        }
      ]
    },
    {
      "Instructions": [
        {
          "$Comment": "Seek toward leash point set by Java; see Component_Instruction_Aetherhaven_Autonomy_Poi_Travel.",
          "Sensor": { "Type": "State", "State": "AetherhavenAutonomy", "IgnoreMissingSetState": true },
          "Instructions": [{ "Reference": "Component_Instruction_Aetherhaven_Autonomy_Poi_Travel" }]
        },
        {
          "Sensor": { "Type": "State", "State": "Idle" },
          "Instructions": [
            {
              "Reference": "Component_Instruction_Aetherhaven_Town_Villager_Rect_Wander_Idle",
              "Modify": {
                "WanderRectTimer": { "Compute": "AetherhavenWanderPhaseTime" },
                "PauseTimer": { "Compute": "AetherhavenPausePhaseTime" }
              }
            }
          ]
        },
        {
          "$Comment": "$Interaction cannot live in a referenced Component (engine validation); duplicate this block for dialogue roles.",
          "Sensor": {
            "Type": "State",
            "State": "$Interaction"
          },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": {
                "Type": "Target",
                "Range": 16
              },
              "HeadMotion": {
                "Type": "Watch"
              }
            },
            {
              "Sensor": {
                "Type": "Any"
              },
              "BodyMotion": {
                "Type": "Nothing"
              }
            }
          ]
        }
      ]
    }
  ],
  "InteractionInstruction": {
    "Instructions": [
      {
        "Sensor": { "Type": "Not", "Sensor": { "Type": "CanInteract", "ViewSector": 360 } },
        "Actions": [{ "Type": "SetInteractable", "Interactable": false }]
      },
      {
        "Continue": true,
        "Sensor": { "Type": "Any" },
        "Actions": [
          { "Type": "SetInteractable", "Interactable": true, "Hint": "aetherhaven_misc.aetherhaven.interaction.dialogue" }
        ]
      },
      {
        "Sensor": { "Type": "HasInteracted" },
        "Instructions": [
          {
            "Sensor": { "Type": "Not", "Sensor": { "Type": "State", "State": "$Interaction" } },
            "Actions": [
              { "Type": "LockOnInteractionTarget" },
              { "Type": "OpenAetherhavenDialogue", "VillagerKind": "fisherman" }
            ]
          }
        ]
      }
    ]
  },
  "NameTranslationKey": { "Compute": "NameTranslationKey" }
}
