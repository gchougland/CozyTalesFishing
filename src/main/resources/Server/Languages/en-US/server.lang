items.CozyFishing_Wooden_Rod.name = Wooden Fishing Rod
items.CozyFishing_Wooden_Rod.description = Hold to charge your cast, release to throw the bobber. Hold primary to reel in, secondary to recall.\n\nFight Stamina: 110\nStamina Regen: 22/s
items.CozyFishing_Iron_Rod.name = Iron Fishing Rod
items.CozyFishing_Iron_Rod.description = Hold to charge your cast, release to throw the bobber. Hold primary to reel in, secondary to recall.\n\nFight Stamina: 125\nStamina Regen: 24/s
items.CozyFishing_Thorium_Rod.name = Thorium Fishing Rod
items.CozyFishing_Thorium_Rod.description = Hold to charge your cast, release to throw the bobber. Hold primary to reel in, secondary to recall.\n\nFight Stamina: 168\nStamina Regen: 32/s
