items.CozyFishing_Adamantite_Rod.description = Hold to charge your cast, release to throw the bobber. Hold primary to reel in, secondary to recall.\n\nFight Stamina: 220\nStamina Regen: 38/s
items.CozyFishing_Fishing_Journal.name = Fishing Journal
items.CozyFishing_Fishing_Journal.description = A worn journal for recording every fish in the waters. Use it to browse your discoveries and study their habits.
items.CozyFishing_Sunken_Treasure.name = Sunken Treasure
items.CozyFishing_Sunken_Treasure.description = A waterlogged cache of forgotten riches. Use to open.
items.CozyFishing_Message_In_A_Bottle.name = Message in a Bottle
items.CozyFishing_Message_In_A_Bottle.description = A sealed note washed ashore. Use to read its contents.
items.CozyFishing_Bobber_Trash.name = Trash Bobber
items.CozyFishing_Bobber_Trash.description = Greatly increases trash catches while fishing. High durability.\n\nEquip to a fishing rod with Use (F).
items.CozyFishing_Bobber_Treasure.name = Treasure Bobber
items.CozyFishing_Bobber_Treasure.description = Increases treasure catches while fishing. Low durability.\n\nEquip to a fishing rod with Use (F).
items.CozyFishing_Bobber_Quality.name = Quality Bobber
items.CozyFishing_Bobber_Quality.description = Increases the chance of catching larger fish. Medium durability.\n\nEquip to a fishing rod with Use (F).
items.CozyFishing_Bobber_Trap.name = Trap Bobber
items.CozyFishing_Bobber_Trap.description = Slows hooked fish when they flee, making fights easier. Medium durability.\n\nEquip to a fishing rod with Use (F).
items.CozyFishing_Bobber_Spinner.name = Spinner
items.CozyFishing_Bobber_Spinner.description = Makes fish notice your bobber from farther away. Medium durability.\n\nEquip to a fishing rod with Use (F).
items.CozyFishing_Bobber_Decorated_Spinner.name = Decorated Spinner
items.CozyFishing_Bobber_Decorated_Spinner.description = Makes fish notice your bobber from even farther away. Medium durability.\n\nEquip to a fishing rod with Use (F).
items.CozyFishing_Bobber.name = Template Bobber
items.CozyFishing_Bobber.description = Internal template for bobber items.
